{
  "manifest_version": 3,
  "name": "JobTrail",
  "version": "1.2.0",
  "description": "Scan job listings on LinkedIn, Naukri and Google, filter them, send them to a Google Sheet, check how well your resume matches each role, and find people to reach out to for referrals.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "identity",
    "alarms",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.naukri.com/*",
    "https://www.google.com/*",
    "https://sheets.googleapis.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.groq.com/*",
    "https://api.adzuna.com/*",
    "https://jsearch.p.rapidapi.com/*",
    "https://docs.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "JobTrail",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "oauth2": {
    "client_id": "REPLACE_WITH_YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/spreadsheets"
    ]
  }
}